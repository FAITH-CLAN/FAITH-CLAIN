# ====================================
# NEGO-TECH Bot Configuration
# ====================================
# 📋 SETUP INSTRUCTIONS:
# 1. Rename this file from sample.env to .env
# 2. Fill in the required values below
# 3. Run: npm start:pair (for pairing code)
# 4. Or: npm start (to connect with existing session)
# ====================================

# 🔐 SESSION & AUTHENTICATION
# For first time setup, use pairing code instead
SESSION_ID=

# Phone number for pairing code (without + symbol)
# Examples: 923051391005 (Pakistan), 2348123456789 (Nigeria), 919876543210 (India)
# Leave empty to manually enter during startup
PAIRING_NUMBER=

# 🔑 SECURITY: Restart PIN (4-6 digits) to protect bot from unauthorized restart
# ⚠️ Change this immediately after setup!
RESTART_PIN=0000

# 🌐 SERVER
PORT=5000

# 🎯 BOT SETTINGS
BOT_NAME=NEGO-CLAN
BOT_OWNER=Nego
OWNER_NUMBER=255691927494,255628294159

# 📱 COMMAND PREFIX
# Multiple prefixes supported (comma-separated)
PREFIXES=.,!,/,#

# 🎨 BOT CUSTOMIZATION
PACKNAME=NEGO-TECH
TIMEZONE=Africa/Dar es salaam

# 🛡️ COMMAND MODE
# public = anyone can use commands
# private = only owner can use commands
# group = works only in groups
COMMAND_MODE=public

# 📊 STORAGE
MAX_STORE_MESSAGES=50

# 🖼️ API KEYS (Optional)
# Remove background from images
REMOVEBG_KEY=

# 🎵 Music & Media
GIPHY_API_KEY=qnl7ssQChTdPjsKta2Ax2LMaGXz303tq

# 🗄️ DATABASE (Optional)
# Leave empty to use JSON file storage (default)
# Uncomment and fill based on your database choice:

# MongoDB
# MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname

# PostgreSQL
# POSTGRES_URL=postgresql://user:password@localhost:5432/dbname

# MySQL
# MYSQL_URL=mysql://user:password@localhost:3306/dbname

# SQLite (file path)
# DB_URL=./data/baileys.db

# 🔗 LINKS & SOCIAL
# YouTube Channel
YT_CHANNEL=Xchristech

# WhatsApp Channel Link
CHANNEL_LINK=https://whatsapp.com/channel/0029VbBvGgyFsn0alyIDjw0z

# Bot Description
DESCRIPTION=High performance multi-device WhatsApp bot powered by NEGO-TECH

# ⚙️ ADVANCED OPTIONS (Optional)

# Enable debugging
# DEBUG=whiskeysockets:*

# Node environment
# NODE_ENV=production

# Database logging
# DB_LOG=true

# Verbose output
# VERBOSE=true

# ====================================
# SETUP QUICK START
# ====================================
# First Time Setup with Pairing:
#   1. npm install
#   2. PAIRING_NUMBER=923051391005 npm run start:pair
#   3. Paste pairing code in WhatsApp Linked Devices
#
# Regular Start:
#   npm start
#
# Optimized Start:
#   npm run start:optimized
# ====================================

